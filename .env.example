# ══════════════════════════════════════════════════════════════════════════════
# goszakup-agent — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── OWS v3 API ────────────────────────────────────────────────────────────────
OWS_BASE_URL=https://ows.goszakup.gov.kz
OWS_TOKEN=your_ows_bearer_token_here
OWS_GRAPHQL_URL=https://ows.goszakup.gov.kz/v3/graphql
OWS_RATE_LIMIT_RPS=5          # requests per second (be polite to the portal)
OWS_TIMEOUT_SECONDS=30
OWS_RPS_ADAPTIVE=1            # enable adaptive RPS (1=yes, 0=no)
OWS_RPS_MIN=1                 # lower bound for adaptive RPS
OWS_RPS_MAX=20                # upper bound for adaptive RPS
OWS_RPS_STEP=1                # add this many RPS after stable window
OWS_RPS_SUCCESS_WINDOW=50     # successful requests before step up
OWS_TRD_BUY_CACHE_MAX=20000   # max cached announcements per process
OWS_TRD_BUY_CACHE_TTL=3600    # seconds to keep announcement cache
OWS_TRD_BUY_CACHE_MISS_TTL=300# seconds to keep negative cache
KATO_SKIP_MIN_ROWS=16000      # skip ref_kato reload if table already complete

# ── AI / LLM ──────────────────────────────────────────────────────────────────
AI_BASE_URL=https://nitec-ai.kz/api
AI_API_KEY=your_nitec_ai_key_here
AI_MODEL=openai/gpt-oss-120b
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.1            # low = more deterministic / factual

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=goszakup
POSTGRES_USER=goszakup_user
POSTGRES_PASSWORD=change_me_strong_password_here
DATABASE_URL=postgresql://goszakup_user:change_me_strong_password_here@localhost:5432/goszakup

# ── Redis (cache) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=redis_change_me
CACHE_TTL_SECONDS=3600        # 1 hour default

# ── Milvus (vector store) ─────────────────────────────────────────────────────
MILVUS_HOST=milvus
MILVUS_PORT=19530

# ── App settings ──────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=generate_a_random_32char_string_here
ETL_CONCURRENCY=2             # parallel BINs per loader
RESUME_BACKSTEP=20000         # finite backstep for safe restarts

# ── Analytics ────────────────────────────────────────────────────────────────
ANALYTICS_DB_PATH=data/analytics.duckdb
ANALYTICS_PARQUET_DIR=data/parquet
FAIR_PRICE_MIN_N=20
PLANS_KATO_REFRESH_MODE=incremental
PLANS_SPEC_REFRESH_MODE=incremental
ACTS_REFRESH_MODE=incremental
TREASURY_PAY_REFRESH_MODE=incremental
RAW_WORKER_CHECKPOINT_EVERY=1
RAW_WORKER_BATCH_SIZE=500

# ── Demo services ─────────────────────────────────────────────────────────────
ANALYTICS_API_URL=http://localhost:8001
AGENT_API_URL=http://localhost:8002

# ── Target organisations (BINs) ───────────────────────────────────────────────
# Comma-separated list — matches ТЗ exactly
TARGET_BINS=000740001307,020240002363,020440003656,030440003698,050740004819,051040005150,100140011059,120940001946,140340016539,150540000186,171041003124,210240019348,210240033968,210941010761,230740013340,231040023028,780140000023,900640000128,940740000911,940940000384,960440000220,970940001378,971040001050,980440001034,981140001551,990340005977,990740002243

# ── Data range ────────────────────────────────────────────────────────────────
DATA_YEAR_FROM=2024
DATA_YEAR_TO=2026
