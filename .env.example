# ══════════════════════════════════════════════════════════════════════════════
# goszakup-agent — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── OWS v3 API ────────────────────────────────────────────────────────────────
OWS_BASE_URL=https://ows.goszakup.gov.kz
OWS_TOKEN=your_ows_bearer_token_here
OWS_GRAPHQL_URL=https://ows.goszakup.gov.kz/v3/graphql
OWS_RATE_LIMIT_RPS=5          # requests per second (be polite to the portal)
OWS_TIMEOUT_SECONDS=30

# ── AI / LLM ──────────────────────────────────────────────────────────────────
AI_BASE_URL=https://nitec-ai.kz/api
AI_API_KEY=your_nitec_ai_key_here
AI_MODEL=openai/gpt-oss-120b
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.1            # low = more deterministic / factual

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=goszakup
POSTGRES_USER=goszakup_user
POSTGRES_PASSWORD=change_me_strong_password_here
DATABASE_URL=postgresql://goszakup_user:change_me_strong_password_here@postgres:5432/goszakup

# ── Redis (cache) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600        # 1 hour default

# ── Milvus (vector store) ─────────────────────────────────────────────────────
MILVUS_HOST=milvus
MILVUS_PORT=19530

# ── App settings ──────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=generate_a_random_32char_string_here

# ── Target organisations (BINs) ───────────────────────────────────────────────
# Comma-separated list — matches ТЗ exactly
TARGET_BINS=000740001307,020240002363,020440003656,030440003698,050740004819,051040005150,100140011059,120940001946,140340016539,150540000186,171041003124,210240019348,210240033968,210941010761,230740013340,231040023028,780140000023,900640000128,940740000911,940940000384,960440000220,970940001378,971040001050,980440001034,981140001551,990340005977,990740002243

# ── Data range ────────────────────────────────────────────────────────────────
DATA_YEAR_FROM=2024
DATA_YEAR_TO=2026
